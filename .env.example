VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Google OAuth — client ID and redirect URI are referenced in the browser
# to build the consent URL, so they keep the VITE_ prefix. The client secret
# is used only by server endpoints under api/youtube/oauth/* and MUST NOT be
# prefixed with VITE_ (anything VITE_-prefixed is inlined into the public JS bundle).
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=
GOOGLE_CLIENT_SECRET=

# Zoom OAuth — same rule: client_id / redirect_uri stay VITE_-prefixed for
# the browser; client_secret is server-only.
VITE_ZOOM_CLIENT_ID=
VITE_ZOOM_REDIRECT_URI=
ZOOM_CLIENT_SECRET=

# Zoom webhook verification token — server-only.
ZOOM_SECRET_TOKEN=

VITE_TELEGRAM_BOT_USERNAME=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Public origin used to build deep links inside outbound Telegram messages
# (e.g. https://moc-console.example.com). Server-only — do NOT VITE_-prefix.
# When unset, falls back to https://$VERCEL_URL.
APP_BASE_URL=

# Shared HMAC secret used by external apps (requests/bookings) to sign their
# POSTs to /api/notifications/requests and /api/notifications/bookings.
# Sender computes hex(HMAC-SHA256(secret, JSON.stringify(body))) and sends it
# in the X-Signature header. Server-only.
NOTIFICATIONS_INGEST_SECRET=
