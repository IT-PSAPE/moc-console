VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
VITE_WORKSPACE_ID=

# Outbound notification relay (api/notify/*). Both must be set in
# production for Telegram notifications to fire; if either is missing the
# relay no-ops silently so local/dev environments stay quiet.
# - MOC_CONSOLE_BASE_URL: origin of the moc-console deployment, e.g.
#   https://moc-console.example.com (no trailing slash).
# - NOTIFICATIONS_INGEST_SECRET: shared HMAC secret. Must match the value
#   configured in moc-console's environment.
MOC_CONSOLE_BASE_URL=
NOTIFICATIONS_INGEST_SECRET=
