{
  "name": "moc-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:console": "bun --filter moc-console dev",
    "dev:request": "bun --filter moc-request dev",
    "build:console": "bun --filter moc-console build",
    "build:request": "bun --filter moc-request build",
    "build": "bun --filter '*' build",
    "lint": "bun --filter '*' lint"
  }
}
